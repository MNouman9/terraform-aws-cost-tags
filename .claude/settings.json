{
  "enabledPlugins": {},
  "permissions": {
    "allow": [
      "Bash(terraform fmt:*)",
      "Bash(terraform init:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform output:*)",
      "Bash(terraform state list:*)",
      "Bash(terraform state show:*)",
      "Bash(terraform import:*)",
      "Bash(tfsec:*)",
      "Bash(checkov:*)",
      "Bash(infracost:*)",
      "Bash(terraform-docs:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws eks describe-nodegroup:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Bash(terraform destroy:*)",
      "Bash(terraform force-unlock:*)",
      "Bash(aws s3 rb:*)",
      "Bash(aws dynamodb delete-table:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-use/validate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-tool-use/fmt.sh"
          }
        ]
      }
    ]
  }
}
